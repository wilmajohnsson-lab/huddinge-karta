{
  "name": "huddinge-karta",
  "version": "0.1.0",
  "description": "Interactive event & culture map for Huddinge municipality",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/js",
    "test": "vitest run",
    "format": "prettier --write src/js src/css",
    "validate": "node scripts/validate-items.mjs",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "og": "node scripts/svg-to-png.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/source-sans-3": "^5.2.9",
    "leaflet": "^1.9.4"
  }
}
